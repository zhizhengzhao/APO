# Copy to `.env` and fill in. NEVER commit the real `.env` (it is gitignored).
# All credentials are read from the environment; none are hardcoded in code.

# --- Worker / judge model API (required for training, eval, and data probing) ---
# The released experiments use Aliyun DashScope (Qwen 3-tier pool: flash/plus/max).
DASHSCOPE_API_KEY=

# --- Optional alternate OpenAI-compatible backends (not used by released runs) ---
# DEEPSEEK_API_KEY=
# GPUGEEK_API_KEY=

# --- Tool: web/arxiv/wikipedia search (only needed if a role uses search tools) ---
# Get a key at https://serper.dev . Wikipedia falls back to its keyless REST API.
SERPER_API_KEY=

# --- HuggingFace token (only needed to RE-BUILD corpora via scripts/collect_categories.py;
#     the frozen corpora in data/categories/ need no token) ---
# HF_TOKEN=

# --- Optional: per-category python_exec wall-clock override (seconds) ---
# ARCH_PYTHON_TIMEOUT_S=120
